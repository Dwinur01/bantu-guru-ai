datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                 Int            @id @default(autoincrement())
  name               String
  email              String         @unique
  password_hash      String?
  google_id          String?
  plan               String         @default("free") // Mapped to String for SQLite compatibility
  quota_remaining    Int            @default(5)
  quota_reset_at     DateTime?
  email_verified     Boolean        @default(false)
  verification_token String?        @unique
  scheduled_deletion DateTime?                        // Tanggal penghapusan terjadwal (soft-delete 24j)
  deletion_token     String?        @unique           // Token unik untuk membatalkan penghapusan
  created_at         DateTime       @default(now())
  
  refresh_tokens     RefreshToken[]
  documents          Document[]
  subscriptions      Subscription[]

  @@map("users")
}

model RefreshToken {
  id         Int      @id @default(autoincrement())
  user_id    Int
  token      String   @unique
  expires_at DateTime
  is_revoked Boolean  @default(false)
  
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Document {
  id         Int      @id @default(autoincrement())
  user_id    Int
  type       String   // Mapped to String for SQLite compatibility
  title      String
  input_data String
  gcs_path   String?
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Subscription {
  id                Int                @id @default(autoincrement())
  user_id           Int
  plan              String             // Mapped to String for SQLite compatibility
  midtrans_order_id String             @unique
  status            String             @default("pending") // Mapped to String for SQLite compatibility
  started_at        DateTime?
  expires_at        DateTime?
  amount            Float

  user              User               @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@map("subscriptions")
}
