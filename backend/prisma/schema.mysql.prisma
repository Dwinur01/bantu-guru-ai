datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Plan {
  free
  saset
  basic
  pro
  kkg
}

enum DocType {
  rpp
  soal
  modul
  modul_ajar
  rapor
  pmm
}

enum SubscriptionStatus {
  pending
  active
  expired
  cancelled
}

model User {
  id                 BigInt         @id @default(autoincrement()) @db.BigInt
  name               String         @db.VarChar(100)
  email              String         @unique @db.VarChar(255)
  password_hash      String?        @db.VarChar(255) // NULL jika login Google
  google_id          String?        @db.VarChar(100) // NULL jika login biasa
  plan               Plan           @default(free)
  quota_remaining    Int            @default(5)
  quota_reset_at     DateTime?      @db.Timestamp
  email_verified     Boolean        @default(false) @db.TinyInt
  verification_token String?        @unique @db.VarChar(255)
  scheduled_deletion DateTime?      @db.Timestamp   // Tanggal penghapusan terjadwal (soft-delete 24j)
  deletion_token     String?        @unique @db.VarChar(255) // Token unik untuk membatalkan penghapusan
  created_at         DateTime       @default(now()) @db.Timestamp
  
  refresh_tokens     RefreshToken[]
  documents          Document[]
  subscriptions      Subscription[]

  @@map("users")
}

model RefreshToken {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  user_id    BigInt   @db.BigInt
  token      String   @unique @db.VarChar(512)
  expires_at DateTime @db.Timestamp
  is_revoked Boolean  @default(false)
  
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Document {
  id         BigInt   @id @default(autoincrement()) @db.BigInt
  user_id    BigInt   @db.BigInt
  type       DocType
  title      String   @db.VarChar(255)
  input_data Json     @db.Json
  gcs_path   String?  @db.VarChar(500)
  is_public  Boolean  @default(false) @db.TinyInt // Apakah dokumen dibagikan ke perpustakaan publik
  shared_at  DateTime? @db.Timestamp          // Kapan dokumen dibagikan ke perpustakaan
  created_at DateTime @default(now()) @db.Timestamp

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("documents")
}

model Subscription {
  id                BigInt             @id @default(autoincrement()) @db.BigInt
  user_id           BigInt             @db.BigInt
  plan              Plan
  midtrans_order_id String             @unique @db.VarChar(100)
  status            SubscriptionStatus @default(pending)
  started_at        DateTime?          @db.Timestamp
  expires_at        DateTime?          @db.Timestamp
  amount            Decimal            @db.Decimal(10, 2)

  user              User               @relation(fields: [user_id], references: [id], onDelete: Restrict)

  @@map("subscriptions")
}
