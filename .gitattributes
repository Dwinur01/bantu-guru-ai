# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files to always normalize
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.html text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.prisma text eol=lf
*.env.example text eol=lf
*.sql text eol=lf
*.sh text eol=lf

# Binary files — never modify line endings
*.db binary
*.docx binary
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
